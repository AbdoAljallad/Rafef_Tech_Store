VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:3000

# Local frontend review only. Mock auth is disabled in production builds.
VITE_USE_MOCK_AUTH=false

# Seeded API-only assistant account for OpenClaw. Leave empty to keep it disabled.
SEED_AI_ASSISTANT_PASSWORD=change-this-ai-assistant-password

# n8n integration. The webhook path must match your active n8n workflow trigger.
N8N_WEBHOOK_URL=http://host.docker.internal:5678/webhook/rafef-tech
N8N_HEALTH_URL=http://host.docker.internal:5678/healthz
N8N_SHARED_SECRET=change-this-n8n-secret

# Backend integration health. On staging this reaches OpenClaw through a Docker bridge proxy.
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18790
INTEGRATION_HTTP_TIMEOUT_MS=3000
